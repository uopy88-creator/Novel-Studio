# Novel Studio — 환경 변수 예시
#
# [로컬 개발]
# 1. 이 파일을 복사해서 `.env.local` 을 만드세요.
# 2. Supabase 대시보드 → Project Settings → API 에서 값을 붙여 넣으세요.
# 3. Authentication → Providers → Email 이 켜져 있는지 확인하세요.
# 4. 개발 중 바로 로그인하려면 Confirm email 을 끄세요. (README 참고)
# 5. `npm run dev` 를 다시 시작하세요.
#
# [Vercel 배포]
# Vercel 프로젝트 → Settings → Environment Variables 에
# 아래 두 변수를 Production / Preview 에 동일하게 등록하세요.
# (`.env.local` 은 Git에 올리지 않습니다.)
#
# 필수 — Supabase 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
#
# 필수 — anon public key (service_role 키는 절대 넣지 마세요)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

#
# 선택 — 국립국어원 표준국어대사전 Open API 키
# Sentence Assistant 「단어」탭 뜻풀이에 사용합니다.
# https://stdict.korean.go.kr/openapi/openApiRegister.do
# 없으면 로컬 폴백 사전(소수 단어)만 동작합니다.
STDICT_API_KEY=
